import requests
import json
 
# 模拟浏览器请求，抓取公开类目榜单数据
headers = {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
}
 
# 海外平台公开品类数据接口（公开免费数据源）
def get_hot_category():
    url = "https://xxx.open.api/category/rank" # 公开类目数据源接口
    res = requests.get(url, headers=headers, timeout=10)
    data = json.loads(res.text)
    # 筛选高热度、低竞争优质类目
    hot_category = [item for item in data["list"] if item["heat"] > 80 and item["compete"] < 40]
    print("当前优质细分类目资源：")
    for cate in hot_category:
        print(f"类目名称：{cate['name']}，热度值：{cate['heat']}，关联话题：{cate['tag']}")
 
if __name__ == "__main__":
    get_hot_category()
